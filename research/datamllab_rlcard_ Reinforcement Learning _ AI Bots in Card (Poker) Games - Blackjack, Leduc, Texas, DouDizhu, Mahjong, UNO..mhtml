<p dir=3D"auto">A <strong>short example</strong> is as below.</p>
<div class=3D"highlight highlight-source-python notranslate position-relati=
ve overflow-auto" dir=3D"auto"><pre><span class=3D"pl-k">import</span> <spa=
n class=3D"pl-s1">rlcard</span>
<span class=3D"pl-k">from</span> <span class=3D"pl-s1">rlcard</span>.<span =
class=3D"pl-s1">agents</span> <span class=3D"pl-k">import</span> <span clas=
s=3D"pl-v">RandomAgent</span>

<span class=3D"pl-s1">env</span> <span class=3D"pl-c1">=3D</span> <span cla=
ss=3D"pl-s1">rlcard</span>.<span class=3D"pl-c1">make</span>(<span class=3D=
"pl-s">'blackjack'</span>)
<span class=3D"pl-s1">env</span>.<span class=3D"pl-c1">set_agents</span>([<=
span class=3D"pl-en">RandomAgent</span>(<span class=3D"pl-s1">num_actions</=
span><span class=3D"pl-c1">=3D</span><span class=3D"pl-s1">env</span>.<span=
 class=3D"pl-c1">num_actions</span>)])

<span class=3D"pl-en">print</span>(<span class=3D"pl-s1">env</span>.<span c=
lass=3D"pl-c1">num_actions</span>) <span class=3D"pl-c"># 2</span>
<span class=3D"pl-en">print</span>(<span class=3D"pl-s1">env</span>.<span c=
lass=3D"pl-c1">num_players</span>) <span class=3D"pl-c"># 1</span>
<span class=3D"pl-en">print</span>(<span class=3D"pl-s1">env</span>.<span c=
lass=3D"pl-c1">state_shape</span>) <span class=3D"pl-c"># [[2]]</span>
<span class=3D"pl-en">print</span>(<span class=3D"pl-s1">env</span>.<span c=
lass=3D"pl-c1">action_shape</span>) <span class=3D"pl-c"># [None]</span>

<span class=3D"pl-s1">trajectories</span>, <span class=3D"pl-s1">payoffs</s=
pan> <span class=3D"pl-c1">=3D</span> <span class=3D"pl-s1">env</span>.<spa=
n class=3D"pl-c1">run</span>()</pre><div class=3D"zeroclipboard-container">
    <clipboard-copy aria-label=3D"Copy" class=3D"ClipboardButton btn btn-in=
visible js-clipboard-copy m-2 p-0 d-flex flex-justify-center flex-items-cen=
ter" data-copy-feedback=3D"Copied!" data-tooltip-direction=3D"w" value=3D"i=
mport rlcard
from rlcard.agents import RandomAgent

env =3D rlcard.make('blackjack')
env.set_agents([RandomAgent(num_actions=3Denv.num_actions)])

